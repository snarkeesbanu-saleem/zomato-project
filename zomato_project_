      "source": [
        "# Expand Contraction\n",
        "import contractions\n",
        "\n",
        "def expand_contractions(text):\n",
        "    return contractions.fix(text)\n",
        "\n",
        "df['reviews'] = df['reviews'].astype(str).apply(expand_contractions)\n"
