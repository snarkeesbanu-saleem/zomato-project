      },
      "outputs": [],
      "source": [
        "# Remove White spaces\n",
        "def remove_whitespace(text):\n",
        "    return ' '.join(text.split())\n",
        "\n",
        "df['reviews'] = df['reviews'].apply(remove_whitespace)\n"
      ]
