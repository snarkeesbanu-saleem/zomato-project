        "id": "88JnJ1jN3w7j"
      },
      "outputs": [],
      "source": [
        "# Lower Casing\n",
        "def to_lower(text):\n",
        "    return text.lower()\n",
        "\n",
        "df['reviews'] = df['reviews'].apply(to_lower)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "XkPnILGE3zoT"
